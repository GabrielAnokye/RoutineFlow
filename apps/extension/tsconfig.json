{
  "extends": "../../tsconfig.web.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "src",
    "outDir": "dist-types",
    "declaration": true,
    "emitDeclarationOnly": true,
    "types": ["chrome", "vite/client"],
    "tsBuildInfoFile": "dist-types/.tsbuildinfo"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "references": [
    { "path": "../../packages/shared-types" },
    { "path": "../../packages/ui" }
  ]
}
