{
  "name": "routineflow",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "corepack pnpm build:packages && concurrently -n extension,runner -c blue,green \"corepack pnpm --filter @routineflow/extension dev\" \"corepack pnpm --filter @routineflow/runner dev\"",
    "build": "corepack pnpm -r build",
    "build:packages": "corepack pnpm -r --filter \"./packages/*\" build",
    "build:extension": "corepack pnpm --filter @routineflow/extension build",
    "build:runner": "corepack pnpm --filter @routineflow/runner build",
    "build:bridge": "corepack pnpm --filter @routineflow/bridge-host build",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "vitest run apps/runner/src/app.test.ts apps/runner/src/core/executor.test.ts packages/db/src/index.test.ts",
    "test:e2e": "corepack pnpm build && playwright test",
    "test:all": "corepack pnpm test:unit && corepack pnpm test:e2e",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b --pretty false",
    "check": "corepack pnpm lint && corepack pnpm typecheck && corepack pnpm test:unit",
    "clean": "corepack pnpm -r clean && rimraf coverage playwright-report test-results",
    "release:build": "corepack pnpm clean && corepack pnpm build",
    "release:verify": "corepack pnpm check && corepack pnpm test:e2e",
    "release:package": "node scripts/package-release.mjs",
    "audit:manifest": "node scripts/audit-manifest.mjs",
    "install:bridge": "corepack pnpm --filter @routineflow/bridge-host install:bridge",
    "uninstall:bridge": "corepack pnpm --filter @routineflow/bridge-host uninstall:bridge",
    "diagnose": "node scripts/diagnose.mjs",
    "db:backup": "node scripts/db-backup.mjs",
    "db:restore": "node scripts/db-restore.mjs",
    "local:install": "node scripts/local-install.mjs",
    "local:uninstall": "node scripts/local-uninstall.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.49.1",
    "@types/chrome": "^0.0.286",
    "@types/node": "^22.10.2",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.1",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
